@page "{id:int}"
@model PiscAtlas.WebApp.Pages.Pesqueiro.VerNoMapaModel
@{
    ViewData["Title"] = "Mapa - " + Model.PesqueiroItem.Nome;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="mb-3">
    <a asp-page="./Detalhes" asp-route-id="@Model.PesqueiroItem.PesqueiroId" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Voltar aos Detalhes
    </a>
</div>

<div class="card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-geo-alt-fill text-danger"></i> @Model.PesqueiroItem.Nome</h5>
        <span class="badge bg-light text-dark">@Model.PesqueiroItem.Tipo.ToString().Replace("_", " ")</span>
    </div>
    <div id="mapaCompleto" style="height: 75vh; width: 100%; z-index: 1;"></div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // O Replace é necessário para garantir que o C# não usa vírgulas nas coordenadas
        var lat = @Model.PesqueiroItem.Latitude.ToString().Replace(",", ".");
        var lng = @Model.PesqueiroItem.Longitude.ToString().Replace(",", ".");

        var map = L.map('mapaCompleto').setView([lat, lng], 15);

        // Adiciona a camada do mapa (OpenStreetMap)
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        // Adiciona o pin no mapa
        L.marker([lat, lng]).addTo(map)
            .bindPopup("<b style='font-size: 16px;'>@Model.PesqueiroItem.Nome</b><br/>Pesqueiro").openPopup();
    </script>
}