@page
@model PiscAtlas.WebApp.Pages.Evento.IndexModel
@{
    ViewData["Title"] = "Eventos e Torneios";
    var agora = DateTime.Now;
}

<div class="mb-5 d-flex justify-content-between align-items-start">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-trophy"></i> Eventos e Torneios</h2>
        <p class="text-muted">Participe em competições de pesca em Portugal</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-page="./Criar" class="btn btn-dark fw-medium">
            <i class="bi bi-plus-lg"></i> Criar Evento
        </a>
    }
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    var eventosAtivos = Model.Eventos.Where(e => e.DataFim >= agora).ToList();
    var eventosPassados = Model.Eventos.Where(e => e.DataFim < agora).ToList();
}

@if (!Model.Eventos.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class=\"bi bi-trophy text-muted\" style=\"font-size: 4rem;\"></i>
            <h4 class=\"mt-3 fw-bold\">Sem eventos agendados</h4>
            <p class=\"text-muted\">De momento não existem torneios a decorrer. Volte mais tarde!</p>
        </div>
    </div>
}
else
{
    @if (eventosAtivos.Any())
    {
        <h4 class="fw-bold mb-3"><i class="bi bi-calendar-event"></i> Torneios Ativos</h4>
        <div class="row g-4 mb-5">
            @foreach (var evento in eventosAtivos)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(evento.FotografiaUrl))
                            {
                                <div style="height: 160px; background: #f8f9fa; border-top-left-radius: var(--bs-card-inner-border-radius); border-top-right-radius: var(--bs-card-inner-border-radius);" class="overflow-hidden">
                                    <img src="@evento.FotografiaUrl" class="w-100 h-100" style="object-fit: cover;" alt="@evento.Nome">
                                </div>
                            }
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="fw-bold mb-0">@evento.Nome</h5>
                                @if (evento.DataInicio <= agora && evento.DataFim >= agora)
                                {
                                    <span class="badge bg-success shadow-sm">A Decorrer</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary shadow-sm">Brevemente</span>
                                }
                            </div>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar3"></i> @evento.DataInicio.ToString("dd/MM/yyyy") — @evento.DataFim.ToString("dd/MM/yyyy")
                            </p>
                            <p class="small text-muted mb-3">
                                @(evento.Descricao?.Length > 80 ? evento.Descricao.Substring(0, 80) + "..." : evento.Descricao)
                            </p>
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge bg-light text-dark border"><i class="bi bi-fish"></i> @evento.EspecieAlvo?.Nome</span>
                                <span class="badge bg-light text-dark border"><i class="bi bi-people"></i> @(evento.Inscricoes?.Count ?? 0) inscritos</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                            <div class="d-grid">
                                <a asp-page="./Detalhes" asp-route-id="@evento.EventoId"
                                   class="btn btn-outline-dark fw-medium">
                                    Ver Detalhes <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @if (eventosPassados.Any())
    {
        <h4 class="fw-bold mb-3 text-muted">
            <i class="bi bi-clock-history"></i> Eventos Anteriores
        </h4>
        <div class="row g-3">
            @foreach (var evento in eventosPassados)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm opacity-75">
                        @if (!string.IsNullOrEmpty(evento.FotografiaUrl))
                        {
                            <div style="height: 160px; background: #f8f9fa; border-top-left-radius: var(--bs-card-inner-border-radius); border-top-right-radius: var(--bs-card-inner-border-radius);" class="overflow-hidden">
                                <img src="@evento.FotografiaUrl" class="w-100 h-100" style="object-fit: cover;" alt="@evento.Nome">
                            </div>
                        }
                        <div class="card-body">
                            <h6 class="fw-bold text-muted mb-1">@evento.Nome</h6>
                            <small class="text-muted d-block">
                                @evento.DataInicio.ToString("dd/MM/yyyy") — @evento.DataFim.ToString("dd/MM/yyyy")
                            </small>
                            <small class="text-muted">@evento.EspecieAlvo?.Nome</small>
                        </div>
                        <div class="card-footer bg-white border-0">
                            <a asp-page="./Detalhes" asp-route-id="@evento.EventoId"
                               class="btn btn-sm btn-outline-secondary">Ver Resultados</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}