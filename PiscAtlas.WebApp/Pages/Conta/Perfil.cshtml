@page "{id?}"
@model PiscAtlas.WebApp.Pages.Conta.PerfilModel
@{
    ViewData["Title"] = Model.IsProprioPerfil ? "O Meu Perfil" : "Perfil - " + Model.PerfilUser.NomeCompleto;
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <h2 class="fw-bold mb-0">
        <i class="bi bi-person-circle"></i>
        @(Model.IsProprioPerfil ? "O Meu Perfil" : Model.PerfilUser.NomeCompleto)
    </h2>

    @if (Model.IsProprioPerfil)
    {
        <a asp-page="./EditarPerfil" class="btn btn-outline-dark fw-medium">
            <i class="bi bi-pencil"></i> Editar Perfil
        </a>
    }
    else if (User.Identity?.IsAuthenticated == true)
    {
        <form method="post" asp-page-handler="ToggleSeguir" asp-route-id="@Model.PerfilUser.Id">
            @if (Model.IsSeguindo)
            {
                <button type="submit" class="btn btn-outline-dark fw-bold">
                    <i class="bi bi-person-check-fill"></i> A Seguir
                </button>
            }
            else
            {
                <button type="submit" class="btn btn-primary fw-bold">
                    Seguir
                </button>
            }
        </form>
    }
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4 text-center">
            @if (!string.IsNullOrEmpty(Model.PerfilUser.FotografiaPerfilUrl))
            {
                <img src="@Model.PerfilUser.FotografiaPerfilUrl"
                     alt="Foto de Perfil"
                     class="rounded-circle mx-auto mb-3"
                     style="width: 120px; height: 120px; object-fit: cover;" />
            }
            else
            {
                <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center mx-auto mb-3 fw-bold"
                     style="width: 120px; height: 120px; font-size: 3rem;">
                    @Model.PerfilUser.PrimeiroNome?.Substring(0, 1).ToUpper()
                </div>
            }

            <h4 class="fw-bold mb-0">@Model.PerfilUser.NomeCompleto</h4>
            <p class="text-muted">@@@Model.PerfilUser.NomeUtilizador</p>

            <hr />

            <div class="d-flex justify-content-center gap-4 mb-3">
                <div class="text-center">
                    <h4 class="fw-bold mb-0">@Model.Capturas.Count</h4>
                    <small class="text-muted">Capturas</small>
                </div>
                <div class="text-center">
                    <h4 class="fw-bold mb-0">@Model.TotalSeguidores</h4>
                    <small class="text-muted">Seguidores</small>
                </div>
                <div class="text-center">
                    <h4 class="fw-bold mb-0">@Model.TotalASeguir</h4>
                    <small class="text-muted">A Seguir</small>
                </div>
            </div>

            <div class="mt-2">
                <small class="text-muted">
                    <i class="bi bi-calendar3 me-1"></i>
                    Membro desde @Model.PerfilUser.DataRegisto.ToString("MMMM yyyy", new System.Globalization.CultureInfo("pt-PT"))
                </small>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <h5 class="fw-bold mb-3">
            @(Model.IsProprioPerfil ? "As Minhas Capturas" : "Galeria de Capturas")
        </h5>

        @if (!Model.Capturas.Any())
        {
            <div class="card border-0 shadow-sm text-center py-5">
                <div class="card-body">
                    <i class="bi bi-camera text-muted" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 fw-bold">Ainda sem capturas</h5>
                    @if (Model.IsProprioPerfil)
                    {
                        <p class="text-muted">Registe a sua primeira pesca!</p>
                        <a asp-page="/Captura/Criar" class="btn btn-dark btn-sm">
                            <i class="bi bi-plus-lg"></i> Registar Captura
                        </a>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var c in Model.Capturas)
                {
                    <div class="col-6 col-md-4">
                        <a asp-page="/Captura/Detalhes" asp-route-id="@c.CapturaId" class="text-decoration-none">
                            <div class="card border-0 shadow-sm overflow-hidden hover-shadow transition">
                                <div style="height: 150px; background: #f8f9fa;">
                                    @if (!string.IsNullOrEmpty(c.FotografiaUrl))
                                    {
                                        <img src="@c.FotografiaUrl" alt="@c.Especie?.Nome"
                                             class="w-100 h-100" style="object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center h-100">
                                            <i class="bi bi-image text-secondary fs-3"></i>
                                        </div>
                                    }
                                </div>
                                <div class="card-body p-2 text-center">
                                    <p class="fw-bold small mb-0 text-dark">@c.Especie?.Nome</p>
                                    @if (c.Peso.HasValue)
                                    {
                                        <span class="badge bg-light text-dark border mt-1">@c.Peso kg</span>
                                    }
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</div>