@page
@model PiscAtlas.WebApp.Pages.Conta.EditarPerfilModel
@{
    ViewData["Title"] = "Definições da Conta";
}

<div class="mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-gear-fill text-dark"></i> Definições da Conta</h2>
    <p class="text-muted">Gerencie as suas informações pessoais, segurança e preferências de pesca.</p>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 p-2">
            <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                <button class="nav-link active text-start fw-bold py-3 px-3 rounded-3 d-flex align-items-center gap-2" id="tab-perfil" data-bs-toggle="pill" data-bs-target="#content-perfil" type="button" role="tab">
                    <i class="bi bi-person-badge fs-5"></i> Perfil Público
                </button>
                <button class="nav-link text-start fw-bold py-3 px-3 rounded-3 d-flex align-items-center gap-2 text-dark" id="tab-seguranca" data-bs-toggle="pill" data-bs-target="#content-seguranca" type="button" role="tab">
                    <i class="bi bi-shield-lock fs-5"></i> Segurança
                </button>
                <button class="nav-link text-start fw-bold py-3 px-3 rounded-3 d-flex align-items-center gap-2 text-dark" id="tab-preferencias" data-bs-toggle="pill" data-bs-target="#content-preferencias" type="button" role="tab">
                    <i class="bi bi-sliders fs-5"></i> Preferências & Alertas
                </button>
                <hr class="my-2">
                <button class="nav-link text-start fw-bold py-3 px-3 rounded-3 d-flex align-items-center gap-2 text-danger" id="tab-perigo" data-bs-toggle="pill" data-bs-target="#content-perigo" type="button" role="tab">
                    <i class="bi bi-exclamation-triangle fs-5"></i> Zona Perigosa
                </button>
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        <div class="tab-content" id="v-pills-tabContent">

            <div class="tab-pane fade show active" id="content-perfil" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h4 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-person me-2"></i>Informações Pessoais</h4>

                    <form method="post" asp-page-handler="Perfil">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="d-flex align-items-center gap-4 mb-4 bg-light p-3 rounded-4 border">
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(Model.InputPerfil.FotografiaPerfilUrl))
                                {
                                    <img src="@Model.InputPerfil.FotografiaPerfilUrl" id="previewFoto" class="rounded-circle border shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" alt="Foto" />
                                }
                                else
                                {
                                    <div id="previewFotoDefault" class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center shadow-sm fw-bold fs-3" style="width: 80px; height: 80px;">
                                        @(Model.InputPerfil.PrimeiroNome?.FirstOrDefault() ?? 'U')
                                    </div>
                                    <img src="" id="previewFoto" class="rounded-circle border shadow-sm d-none" style="width: 80px; height: 80px; object-fit: cover;" alt="Foto" />
                                }
                            </div>
                            <div class="flex-grow-1">
                                <label asp-for="InputPerfil.FotografiaPerfilUrl" class="form-label fw-bold small">URL da Imagem de Perfil</label>
                                <input asp-for="InputPerfil.FotografiaPerfilUrl" class="form-control" id="inputFotoUrl" placeholder="https://exemplo.com/minha-foto.jpg" />
                                <span asp-validation-for="InputPerfil.FotografiaPerfilUrl" class="text-danger small"></span>
                                <small class="text-muted d-block mt-1">Cole o link de uma imagem para atualizar o seu avatar.</small>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="InputPerfil.PrimeiroNome" class="form-label fw-bold small"></label>
                                <input asp-for="InputPerfil.PrimeiroNome" class="form-control" />
                                <span asp-validation-for="InputPerfil.PrimeiroNome" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InputPerfil.UltimoNome" class="form-label fw-bold small"></label>
                                <input asp-for="InputPerfil.UltimoNome" class="form-control" />
                                <span asp-validation-for="InputPerfil.UltimoNome" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="InputPerfil.NomeUtilizador" class="form-label fw-bold small">Nome de Utilizador (@@)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0">@@</span>
                                    <input asp-for="InputPerfil.NomeUtilizador" class="form-control border-start-0" />
                                </div>
                                <span asp-validation-for="InputPerfil.NomeUtilizador" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InputPerfil.Email" class="form-label fw-bold small"></label>
                                <input asp-for="InputPerfil.Email" class="form-control" />
                                <span asp-validation-for="InputPerfil.Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="InputPerfil.Telefone" class="form-label fw-bold small"></label>
                            <input asp-for="InputPerfil.Telefone" class="form-control" placeholder="Ex: +351 912 345 678" />
                            <span asp-validation-for="InputPerfil.Telefone" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-dark fw-bold px-4 py-2">
                                <i class="bi bi-floppy me-1"></i> Guardar Alterações
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="tab-pane fade" id="content-seguranca" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h4 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-key me-2"></i>Alterar Palavra-passe</h4>

                    <form method="post" asp-page-handler="Password">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="InputPassword.PasswordAtual" class="form-label fw-bold small"></label>
                            <input asp-for="InputPassword.PasswordAtual" class="form-control" />
                            <span asp-validation-for="InputPassword.PasswordAtual" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="InputPassword.NovaPassword" class="form-label fw-bold small"></label>
                                <input asp-for="InputPassword.NovaPassword" class="form-control" />
                                <span asp-validation-for="InputPassword.NovaPassword" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="InputPassword.ConfirmarPassword" class="form-label fw-bold small"></label>
                                <input asp-for="InputPassword.ConfirmarPassword" class="form-control" />
                                <span asp-validation-for="InputPassword.ConfirmarPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary fw-bold px-4 py-2">
                                <i class="bi bi-shield-check me-1"></i> Atualizar Palavra-passe
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="tab-pane fade" id="content-preferencias" role="tabpanel">
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <h4 class="fw-bold mb-4 border-bottom pb-3"><i class="bi bi-bell me-2"></i>Preferências da Comunidade</h4>

                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <div>
                            <h6 class="fw-bold mb-1">Alertas Pop-up em Tempo Real (SignalR)</h6>
                            <small class="text-muted">Receber notificações instantâneas no canto do ecrã quando há novas publicações.</small>
                        </div>
                        <div class="form-check form-switch fs-4">
                            <input class="form-check-input" type="checkbox" role="switch" id="toggleSignalR" checked>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <div>
                            <h6 class="fw-bold mb-1">Caderneta de Espécies Pública</h6>
                            <small class="text-muted">Permitir que outros pescadores vejam o seu progresso e troféus conquistados.</small>
                        </div>
                        <div class="form-check form-switch fs-4">
                            <input class="form-check-input" type="checkbox" role="switch" id="toggleCaderneta" checked>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h6 class="fw-bold mb-1">Aparecer nos Rankings de Pesca</h6>
                            <small class="text-muted">Participar automaticamente nas classificações de maiores capturas do mês.</small>
                        </div>
                        <div class="form-check form-switch fs-4">
                            <input class="form-check-input" type="checkbox" role="switch" id="toggleRanking" checked>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="content-perigo" role="tabpanel">
                <div class="card border-danger shadow-sm rounded-4 p-4">
                    <h4 class="fw-bold text-danger mb-4 border-bottom border-danger pb-3"><i class="bi bi-exclamation-octagon me-2"></i>Zona Perigosa</h4>

                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                        <div>
                            <h6 class="fw-bold mb-1">Terminar Sessão em Todos os Dispositivos</h6>
                            <small class="text-muted">Se acha que deixou a conta aberta num computador público ou telemóvel antigo.</small>
                        </div>
                        <button type="button" class="btn btn-outline-danger fw-bold" onclick="alert('Funcionalidade de segurança em breve!');">
                            Encerrar Sessões
                        </button>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold text-danger mb-1">Eliminar a Minha Conta</h6>
                            <small class="text-muted">Apaga definitivamente o seu perfil, capturas registadas e caderneta. Não pode ser desfeito.</small>
                        </div>
                        <button type="button" class="btn btn-danger fw-bold" onclick="if(confirm('Tem a certeza absoluta? Esta ação é irreversível!')) { alert('Por razões de segurança, contacte um Administrador para eliminar o registo.'); }">
                            Eliminar Conta
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Script simples para pré-visualizar a foto mal o utilizador cole um URL!
            const inputUrl = document.getElementById("inputFotoUrl");
            const previewFoto = document.getElementById("previewFoto");
            const previewDefault = document.getElementById("previewFotoDefault");

            if (inputUrl) {
                inputUrl.addEventListener("input", function () {
                    const url = this.value.trim();
                    if (url.length > 10 && (url.startsWith("http://") || url.startsWith("https://"))) {
                        previewFoto.src = url;
                        previewFoto.classList.remove("d-none");
                        if (previewDefault) previewDefault.classList.add("d-none");
                    } else if (url.length === 0) {
                        if (previewDefault) {
                            previewFoto.classList.add("d-none");
                            previewDefault.classList.remove("d-none");
                        }
                    }
                });
            }
        });
    </script>
}