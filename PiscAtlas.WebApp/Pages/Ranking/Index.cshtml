@page
@model PiscAtlas.WebApp.Pages.Ranking.IndexModel
@{
    ViewData["Title"] = "Rankings";
}

<div class="mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-trophy"></i> Rankings e Recordes</h2>
    <p class="text-muted">Descubra as maiores capturas registadas na plataforma para cada espécie.</p>
</div>

@* Fita de Filtros Avançados *@
<form method="get" class="card border-0 shadow-sm p-3 mb-5 bg-white rounded-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label fw-medium small text-muted mb-1"><i class="bi bi-calendar3"></i> Período de Tempo</label>
            <select asp-for="TempoFiltro" class="form-select border-0 bg-light" onchange="this.form.submit()">
                <option value="Sempre">De Sempre (All-Time)</option>
                <option value="Ano">Este Ano</option>
                <option value="Mes">Este Mês</option>
            </select>
        </div>
        <div class="col-md-5">
            <label class="form-label fw-medium small text-muted mb-1"><i class="bi bi-geo-alt"></i> Zona / Pesqueiro</label>
            <select asp-for="PesqueiroId" asp-items="Model.Pesqueiros" class="form-select border-0 bg-light" onchange="this.form.submit()">
                <option value="">Todas as Zonas em Portugal</option>
            </select>
        </div>
        <div class="col-md-3">
            <a asp-page="./Index" class="btn btn-outline-secondary w-100">Limpar Filtros</a>
        </div>
    </div>
</form>

@if (!Model.RankingsPorEspecie.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-trophy text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 fw-bold">Nenhum recorde encontrado</h4>
            <p class="text-muted">Ainda não existem capturas aprovadas com os filtros selecionados.</p>
        </div>
    </div>
}
else
{
    @* Gerar um bloco/tabela para CADA espécie que exista no dicionário *@
    <div class="row g-5">
        @foreach (var grupo in Model.RankingsPorEspecie)
        {
            <div class="col-12">
                <div class="d-flex align-items-center mb-3">
                    <h4 class="fw-bold mb-0 text-dark">@grupo.Key</h4>
                    <span class="badge bg-light text-dark border ms-3">Top @grupo.Value.Count</span>
                </div>

                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-4" style="width: 80px;">#</th>
                                    <th>Pescador</th>
                                    <th>Local</th>
                                    <th>Peso</th>
                                    <th>Tamanho</th>
                                    <th>Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var posicao = 1;
                                }
                                @foreach (var captura in grupo.Value)
                                {
                                    <tr class="@(posicao == 1 ? "table-warning bg-opacity-25" : "")">
                                        <td class="ps-4 fw-bold">
                                            @if (posicao == 1)
                                            {
                                                <span class="fs-5 text-warning" title="1º Lugar">🥇</span>
                                            }
                                            else if (posicao == 2)
                                            {
                                                <span class="fs-5 text-secondary" title="2º Lugar">🥈</span>
                                            }
                                            else if (posicao == 3)
                                            {
                                                <span class="fs-5 text-dark" style="color: #cd7f32 !important;" title="3º Lugar">🥉</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted ms-2">@posicao</span>
                                            }
                                        </td>
                                        <td class="fw-medium">@captura.Utilizador?.NomeCompleto</td>
                                        <td class="text-muted small">
                                            <i class="bi bi-geo-alt"></i> @captura.Pesqueiro?.Nome
                                        </td>
                                        <td>
                                            <span class="badge bg-dark fs-6">@captura.Peso kg</span>
                                        </td>
                                        <td>@(captura.Tamanho.HasValue ? captura.Tamanho + " cm" : "—")</td>
                                        <td class="text-muted small">@captura.DataCaptura.ToString("dd MMM yyyy")</td>
                                    </tr>
                                    posicao++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
}