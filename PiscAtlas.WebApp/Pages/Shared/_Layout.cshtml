@using Microsoft.AspNetCore.Identity
@using PiscAtlas.Models.Models
@inject SignInManager<Utilizador> SignInManager
@inject UserManager<Utilizador> UserManager

<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PiscAtlas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2" asp-page="/Home/Index">
                    <i class="bi bi-tsunami"></i> PiscAtlas
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPrincipal">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarPrincipal">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 fw-medium gap-lg-3 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Home/Index"><i class="bi bi-images me-1"></i> Feed</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Pesqueiro/Index"><i class="bi bi-geo-alt me-1"></i> Pesqueiros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Evento/Index"><i class="bi bi-calendar-event me-1"></i> Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Ranking/Index"><i class="bi bi-trophy me-1"></i> Ranking</a>
                        </li>
                    </ul>

                    <form class="d-flex mx-lg-3 my-3 my-lg-0" method="get" action="/Pesquisa">
                        <div class="input-group">
                            <input class="form-control border-secondary bg-light" type="search" name="q" placeholder="Procurar pescadores..." required>
                            <button class="btn btn-outline-secondary bg-light" type="submit">
                                <i class="bi bi-search text-dark"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-lg-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold text-dark d-flex align-items-center gap-2" href="#" id="menuConta" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle fs-5"></i> Conta
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item py-2 fw-bold text-primary" asp-page="/Admin/Index">
                                                <i class="bi bi-shield-lock-fill me-2"></i> Painel Admin
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }

                                    <li>
                                        <a class="dropdown-item py-2" asp-page="/Conta/Perfil">
                                            <i class="bi bi-person me-2"></i> O Meu Perfil
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-page="/Conta/EditarPerfil">
                                            <i class="bi bi-gear me-2"></i> Definições
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Conta/Logout" class="m-0 p-0">
                                            <button type="submit" class="dropdown-item text-danger py-2">
                                                <i class="bi bi-box-arrow-right me-2"></i> Sair
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-flex gap-2">
                                <a class="btn btn-outline-dark fw-bold" asp-page="/Conta/Login">Entrar</a>
                                <a class="btn btn-dark fw-bold" asp-page="/Conta/Registar">Registar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 PiscAtlas. Plataforma digital para pescadores em Portugal.</span>
            <a class="nav-link" asp-page="/Home/Autores">Sobre o Projeto / Autores</a>
        </div>
    </footer>

    <div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index: 1100">
        <div id="notificacaoToast" class="toast align-items-center text-bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-bold fs-6" id="mensagemToast"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificacaoHub")
            .build();

        connection.on("ReceberNotificacao", function (mensagem) {
            document.getElementById("mensagemToast").innerText = mensagem;
            const toastElement = document.getElementById('notificacaoToast');
            const toast = new bootstrap.Toast(toastElement, { delay: 5000 });
            toast.show();
        });

        connection.start().then(function () {
            console.log("SignalR Ligado! À escuta de novas capturas...");
        }).catch(function (err) {
            console.error(err.toString());
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>