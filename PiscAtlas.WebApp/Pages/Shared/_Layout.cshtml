@using Microsoft.AspNetCore.Identity
@using PiscAtlas.Models.Models
@inject SignInManager<Utilizador> SignInManager
@inject UserManager<Utilizador> UserManager
@{
    // O SERVIDOR LÊ DIRETAMENTE A TUA PREFERÊNCIA DA BASE DE DADOS:
    string temaAtual = "light";
    if (SignInManager.IsSignedIn(User))
    {
        var user = await UserManager.GetUserAsync(User);
        if (user?.TemaVisual == "Escuro")
        {
            temaAtual = "dark";
        }
    }
}
<!DOCTYPE html>
<html lang="pt-pt" data-bs-theme="@temaAtual">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PiscAtlas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-body text-body d-flex flex-column min-vh-100 transition-all">
    <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2" asp-page="/Home/Index">
                    <i class="bi bi-tsunami text-primary"></i> PiscAtlas
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarPrincipal">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarPrincipal">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 fw-medium gap-lg-3 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Home/Index"><i class="bi bi-images me-1"></i> Feed</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Pesqueiro/Index"><i class="bi bi-geo-alt me-1"></i> Pesqueiros</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Evento/Index"><i class="bi bi-calendar-event me-1"></i> Eventos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Ranking/Index"><i class="bi bi-trophy me-1"></i> Ranking</a>
                        </li>
                    </ul>

                    <form class="d-flex mx-lg-3 my-3 my-lg-0" method="get" action="/Pesquisa">
                        <div class="input-group">
                            <input class="form-control border-secondary bg-body" type="search" name="q" placeholder="Procurar pescadores..." required>
                            <button class="btn btn-outline-secondary" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-lg-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item me-3 d-flex align-items-center">
                                <a class="btn btn-primary fw-bold d-flex align-items-center gap-2 shadow-sm px-3 rounded-pill" asp-page="/Captura/Criar">
                                    <i class="bi bi-plus-circle-fill fs-6"></i> Publicar Captura
                                </a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold d-flex align-items-center gap-2" href="#" id="menuConta" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle fs-5"></i> Conta
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item py-2 fw-bold text-primary" asp-page="/Admin/Index">
                                                <i class="bi bi-shield-lock-fill me-2"></i> Painel Admin
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <a class="dropdown-item py-2" asp-page="/Conta/Perfil">
                                            <i class="bi bi-person me-2"></i> O Meu Perfil
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item py-2" asp-page="/Conta/EditarPerfil">
                                            <i class="bi bi-gear me-2"></i> Definições
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Conta/Logout" class="m-0 p-0">
                                            <button type="submit" class="dropdown-item text-danger py-2">
                                                <i class="bi bi-box-arrow-right me-2"></i> Sair
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-flex gap-2">
                                <a class="btn btn-outline-primary fw-bold" asp-page="/Conta/Login">Entrar</a>
                                <a class="btn btn-primary fw-bold" asp-page="/Conta/Registar">Registar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-5 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3 bg-body-tertiary">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 PiscAtlas. Plataforma digital para pescadores em Portugal.</span>
            <a class="nav-link" asp-page="/Home/Autores">Sobre o Projeto / Autores</a>
        </div>
    </footer>

    <!-- Contentor para os Toasts, aparecem no canto inferior direito -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="notificacaoGlobalToast" class="toast align-items-center text-bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i id="notificacaoIcone" class="bi bi-info-circle-fill me-2"></i>
                    <strong id="notificacaoTitulo" class="me-auto">Novidade!</strong><br />
                    <span id="notificacaoMensagem">Mensagem aqui.</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <!-- BOOTSTRAP  -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SIGNALR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <!-- SCRIPT DA APLICAÇÃO (SignalR Client) -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Inicializa a ligação ao Hub
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/notificacaoHub") // O mesmo caminho que configuraste no Program.cs
                .withAutomaticReconnect()
                .build();

            // Fica à escuta da mensagem "ReceberNovidade" enviada pelo servidor
            connection.on("ReceberNovidade", function (tipo, titulo, mensagem) {

                // Verifica se o utilizador aceitou ver os alertas SignalR 
                
                let icone = document.getElementById("notificacaoIcone");
                let toastElement = document.getElementById("notificacaoGlobalToast");

                // Limpar classes de cor anteriores
                toastElement.className = "toast align-items-center border-0 text-white";

                if (tipo === "Especie") {
                    icone.className = "bi bi-droplet-fill me-2";
                    toastElement.classList.add("bg-info"); // Cor Azul Clara
                } else if (tipo === "Pesqueiro") {
                    icone.className = "bi bi-geo-alt-fill me-2";
                    toastElement.classList.add("bg-success"); // Cor Verde
                } else if (tipo === "Evento") {
                    icone.className = "bi bi-calendar-event-fill me-2";
                    toastElement.classList.add("bg-warning", "text-dark"); // Cor Amarela
                } else {
                    icone.className = "bi bi-bell-fill me-2";
                    toastElement.classList.add("bg-primary");
                }

                // Inserir os textos
                document.getElementById("notificacaoTitulo").innerText = titulo;
                document.getElementById("notificacaoMensagem").innerText = mensagem;

                // Mostrar o Toast do Bootstrap
                const toast = new bootstrap.Toast(toastElement, { delay: 6000 }); // Desaparece em 6 segundos
                toast.show();
            });

            // Inicia a ligação
            connection.start().catch(function (err) {
                return console.error("Erro ao ligar ao SignalR: ", err.toString());
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>