@using Microsoft.AspNetCore.Identity
@using PiscAtlas.Models.Models
@inject SignInManager<Utilizador> SignInManager
@inject UserManager<Utilizador> UserManager

<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PiscAtlas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3">
            <div class="container">
                @* Mantém MVC por agora *@
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tsunami"></i> PiscAtlas
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                    <ul class="navbar-nav gap-3 fw-medium">
                        @* Estes continuam a apontar para os controladores antigos *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index"><i class="bi bi-geo-alt"></i> Mapa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Pesqueiro" asp-action="Index"><i class="bi bi-geo"></i> Pesqueiros</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Captura/Index"><i class="bi bi-camera"></i> Minhas Capturas</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Especie/Index"><i class="bi bi-book"></i> Caderneta</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Ranking" asp-action="Index"><i class="bi bi-trophy"></i> Rankings</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Evento/Index"><i class="bi bi-calendar-event"></i> Eventos</a>
                        </li>
                    </ul>
                </div>
                <div class="d-flex">
                    <div class="d-flex gap-2 align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div class="dropdown">
                                <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-weight: bold;">
                                        @User.Identity?.Name?.Substring(0, 1).ToUpper()
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Conta" asp-action="Perfil">
                                            <i class="bi bi-person"></i> O Meu Perfil
                                        </a>
                                    </li>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            @* LINK ATUALIZADO PARA RAZOR PAGES *@
                                            <a class="dropdown-item" asp-page="/Admin/Index">
                                                <i class="bi bi-shield-lock"></i> Admin
                                            </a>
                                        </li>
                                    }

                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline" asp-page="/Conta/Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right"></i> Terminar Sessão
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Conta" asp-action="Login" class="btn btn-outline-dark fw-medium">Entrar</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 PiscAtlas. Plataforma digital para pescadores em Portugal.</span>
            <a asp-controller="Home" asp-action="Autores" class="text-decoration-none fw-bold">Sobre o Projeto / Autores</a>
        </div>
    </footer>

    <div class="toast-container position-fixed bottom-0 end-0 p-4" style="z-index: 1100">
        <div id="notificacaoToast" class="toast align-items-center text-bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fw-bold fs-6" id="mensagemToast"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>

    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificacaoHub")
            .build();

        connection.on("ReceberNotificacao", function (mensagem) {
            document.getElementById("mensagemToast").innerText = mensagem;
            const toastElement = document.getElementById('notificacaoToast');
            const toast = new bootstrap.Toast(toastElement, { delay: 5000 });
            toast.show();
        });

        connection.start().then(function () {
            console.log("SignalR Ligado! À escuta de novas capturas...");
        }).catch(function (err) {
            console.error(err.toString());
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>