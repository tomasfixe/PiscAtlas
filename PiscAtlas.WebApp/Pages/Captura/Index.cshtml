@page
@model PiscAtlas.WebApp.Pages.Captura.IndexModel
@{
    ViewData["Title"] = "As Minhas Capturas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-camera"></i> As Minhas Capturas</h2>
        <p class="text-muted mb-0">O seu registo pessoal de pescas</p>
    </div>
    <a asp-page="./Criar" class="btn btn-dark fw-medium">
        <i class="bi bi-plus-lg"></i> Registar Captura
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Capturas.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-camera text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 fw-bold">Ainda não registou capturas</h4>
            <p class="text-muted">Comece já a registar as suas pescas!</p>
            <a asp-page="./Criar" class="btn btn-dark mt-2">
                <i class="bi bi-plus-lg"></i> Adicionar a Primeira Captura
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var captura in Model.Capturas)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(captura.FotografiaUrl))
                        {
                            <img src="@captura.FotografiaUrl" class="card-img-top" alt="Captura" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="bi bi-image text-muted fs-1"></i>
                            </div>
                        }

                        <div class="position-absolute top-0 end-0 p-2">
                            @if (captura.AprovadaPeloAdmin)
                            {
                                <span class="badge bg-success shadow-sm"><i class="bi bi-patch-check-fill"></i> Aprovada</span>
                            }
                            else if (captura.FraudeConfirmada)
                            {
                                <span class="badge bg-danger shadow-sm"><i class="bi bi-exclamation-triangle-fill"></i> Inválida</span>
                            }
                            else if (captura.PossuiProvasVisuais)
                            {
                                <span class="badge bg-warning text-dark shadow-sm"><i class="bi bi-hourglass-split"></i> Em análise</span>
                            }
                        </div>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">@captura.Especie?.Nome</h5>
                        <p class="card-text text-muted small mb-3">
                            <i class="bi bi-geo-alt"></i> @captura.Pesqueiro?.Nome<br />
                            <i class="bi bi-calendar"></i> @captura.DataCaptura.ToString("dd MMM yyyy")
                        </p>
                        <div class="d-flex gap-2 mb-2">
                            @if (captura.Peso.HasValue)
                            {
                                <span class="badge bg-light text-dark border">@captura.Peso kg</span>
                            }
                            @if (captura.Tamanho.HasValue)
                            {
                                <span class="badge bg-light text-dark border">@captura.Tamanho cm</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2 pt-0 pb-3 px-3">
                        <a asp-page="./Detalhes" asp-route-id="@captura.CapturaId"
                           class="btn btn-sm btn-outline-secondary flex-fill">
                            <i class="bi bi-eye"></i> Ver
                        </a>
                        <a asp-page="./Editar" asp-route-id="@captura.CapturaId"
                           class="btn btn-sm btn-outline-dark flex-fill">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <a asp-page="./Eliminar" asp-route-id="@captura.CapturaId"
                           class="btn btn-sm btn-outline-danger flex-fill">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}