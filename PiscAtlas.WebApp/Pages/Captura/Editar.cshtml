@page "{id:int}"
@model PiscAtlas.WebApp.Pages.Captura.EditarModel
@{
    ViewData["Title"] = "Editar Captura";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="mb-4">
            <a asp-page="/Conta/Perfil" class="text-muted text-decoration-none small">
                <i class="bi bi-arrow-left"></i> Voltar ao Perfil
            </a>
            <h2 class="fw-bold mt-2">Editar Captura</h2>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                <input type="hidden" asp-for="CapturaId" />

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.EspecieId" class="form-label fw-medium">Espécie *</label>
                        <select asp-for="Input.EspecieId" asp-items="Model.Especies" class="form-select">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="Input.EspecieId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.PesqueiroId" class="form-label fw-medium">Pesqueiro *</label>
                        <select asp-for="Input.PesqueiroId" asp-items="Model.Pesqueiros" class="form-select">
                            <option value="">-- Selecione --</option>
                        </select>
                        <span asp-validation-for="Input.PesqueiroId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.Peso" class="form-label fw-medium">Peso (kg)</label>
                        <input asp-for="Input.Peso" class="form-control" type="number" step="0.01" min="0" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Tamanho" class="form-label fw-medium">Comprimento (cm)</label>
                        <input asp-for="Input.Tamanho" class="form-control" type="number" step="0.1" min="0" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Notas" class="form-label fw-medium">Notas</label>
                    <textarea asp-for="Input.Notas" class="form-control" rows="3"></textarea>
                </div>

                <hr />

                <!-- Galeria de Fotos Atuais -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Fotografias Atuais</label>
                    @if (Model.FotografiasAtuais.Any())
                    {
                        <div class="row g-3">
                            @foreach (var foto in Model.FotografiasAtuais)
                            {
                                <div class="col-4 col-md-3 text-center">
                                    <img src="@foto.Url" class="img-fluid rounded shadow-sm mb-2" style="height: 100px; width: 100%; object-fit: cover;" />
                                    <div class="form-check d-flex justify-content-center align-items-center">
                                        <input class="form-check-input border-danger me-2" type="checkbox" name="Input.FotosParaRemover" value="@foto.Id" id="rem_@foto.Id">
                                        <label class="form-check-label text-danger small fw-bold" for="rem_@foto.Id">
                                            Eliminar
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                        <small class="d-block text-muted mt-2">Selecione a checkbox das fotografias que deseja apagar.</small>
                    }
                    else
                    {
                        <p class="text-muted small">Sem fotografias de momento.</p>
                    }
                </div>

                <!-- Adicionar Novas Fotos -->
                <div class="mb-4 bg-light p-3 rounded">
                    <label asp-for="Input.NovasFotos" class="form-label fw-bold text-dark">Adicionar Novas Fotografias</label>
                    <input asp-for="Input.NovasFotos" class="form-control" type="file" accept="image/*" multiple />
                    <div class="form-text">Pressione CTRL para selecionar múltiplas fotos.</div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <a asp-page="/Conta/Perfil" class="btn btn-outline-secondary flex-fill">Cancelar</a>
                    <button type="submit" class="btn btn-dark fw-bold flex-fill">
                        <i class="bi bi-save"></i> Guardar Alterações
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}