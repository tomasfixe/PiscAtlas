@page
@model PiscAtlas.WebApp.Pages.Captura.CriarModel
@{
    ViewData["Title"] = "Registar Nova Captura";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-4"><i class="bi bi-camera"></i> Registar Nova Captura</h2>

        <div class="card border-0 shadow-sm p-4">
            <form method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Input.EspecieId" class="form-label fw-bold">Espécie *</label>
                        <select asp-for="Input.EspecieId" class="form-select" asp-items="Model.EspeciesList">
                            <option value="">-- Selecione a Espécie --</option>
                        </select>
                        <span asp-validation-for="Input.EspecieId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.PesqueiroId" class="form-label fw-bold">Pesqueiro *</label>
                        <select asp-for="Input.PesqueiroId" class="form-select" asp-items="Model.PesqueirosList">
                            <option value="">-- Selecione o Pesqueiro --</option>
                        </select>
                        <span asp-validation-for="Input.PesqueiroId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="Input.Peso" class="form-label fw-medium">Peso (kg)</label>
                        <input asp-for="Input.Peso" type="number" step="0.01" class="form-control" placeholder="Ex: 2.5" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.Comprimento" class="form-label fw-medium">Comprimento (cm)</label>
                        <input asp-for="Input.Comprimento" type="number" step="0.1" class="form-control" placeholder="Ex: 45" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.DataCaptura" class="form-label fw-medium">Data da Captura *</label>
                        <input asp-for="Input.DataCaptura" type="date" class="form-control" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.FotosFiles" class="form-label fw-bold">Fotografias</label>
                    <input asp-for="Input.FotosFiles" type="file" class="form-control" accept="image/*" multiple />
                    <div class="form-text">Pode selecionar várias fotografias ao mesmo tempo (Pressione CTRL ao clicar nas fotos).</div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary fw-bold py-2">
                        <i class="bi bi-cloud-arrow-up"></i> Publicar Captura
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>