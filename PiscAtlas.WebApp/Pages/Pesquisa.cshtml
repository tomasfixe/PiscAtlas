@page
@model PiscAtlas.WebApp.Pages.PesquisaModel
@{
    ViewData["Title"] = "Pesquisa: " + Model.Query;
}

<div class="mb-4">
    <h2 class="fw-bold"><i class="bi bi-search"></i> Resultados da Pesquisa</h2>
    @if (!string.IsNullOrWhiteSpace(Model.Query))
    {
        <p class="text-muted">A procurar pescadores por: <strong>"@Model.Query"</strong></p>
    }
</div>

@if (string.IsNullOrWhiteSpace(Model.Query))
{
    <div class="alert alert-info border-0 shadow-sm">
        <i class="bi bi-info-circle"></i> Por favor, insira um nome na barra de pesquisa acima.
    </div>
}
else if (!Model.Resultados.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-emoji-frown text-muted" style="font-size: 3rem;"></i>
            <h5 class="mt-3 fw-bold">Nenhum pescador encontrado.</h5>
            <p class="text-muted">Tente pesquisar por outro nome.</p>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var u in Model.Resultados)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm hover-shadow transition h-100">
                    <div class="card-body d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(u.FotografiaPerfilUrl))
                        {
                            <img src="@u.FotografiaPerfilUrl" class="rounded-circle" style="width: 60px; height: 60px; object-fit: cover;" alt="Foto de @u.NomeCompleto" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center fw-bold" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                @u.PrimeiroNome?.Substring(0, 1).ToUpper()
                            </div>
                        }
                        <div>
                            <h6 class="fw-bold mb-0 text-truncate" style="max-width: 180px;">@u.NomeCompleto</h6>
                            <small class="text-muted d-block mb-2">@@@u.NomeUtilizador</small>
                            <a asp-page="/Conta/Perfil" asp-route-id="@u.Id" class="btn btn-sm btn-outline-dark py-0">
                                Ver Perfil
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}