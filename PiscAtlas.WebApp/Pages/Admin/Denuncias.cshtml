@page
@model PiscAtlas.WebApp.Pages.Admin.DenunciasModel
@using PiscAtlas.Models.Models
@{
    ViewData["Title"] = "Admin — Denúncias";
    var estadoFiltro = Model.EstadoFiltro;
}

<div class="mb-4">
    <a asp-page="./Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
    <h2 class="fw-bold mt-2">Gestão de Denúncias</h2>
</div>

<div class="d-flex gap-2 mb-4">
    <a asp-page="./Denuncias" asp-route-estado="" class="btn btn-sm @(estadoFiltro == null ? "btn-dark" : "btn-outline-dark")">Todas</a>
    <a asp-page="./Denuncias" asp-route-estado="@EstadoDenuncia.Pendente"
       class="btn btn-sm @(estadoFiltro == EstadoDenuncia.Pendente ? "btn-dark" : "btn-outline-dark")">
        Pendentes
    </a>
    <a asp-page="./Denuncias" asp-route-estado="@EstadoDenuncia.Analisada_Valida"
       class="btn btn-sm @(estadoFiltro == EstadoDenuncia.Analisada_Valida ? "btn-dark" : "btn-outline-dark")">
        Válidas
    </a>
    <a asp-page="./Denuncias" asp-route-estado="@EstadoDenuncia.Analisada_Fraude"
       class="btn btn-sm @(estadoFiltro == EstadoDenuncia.Analisada_Fraude ? "btn-dark" : "btn-outline-dark")">
        Fraude
    </a>
</div>

@if (!Model.Denuncias.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
            <h5 class="mt-3 fw-bold">Sem denúncias nesta categoria</h5>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Captura</th>
                        <th>Denunciante</th>
                        <th>Motivo</th>
                        <th>Estado</th>
                        <th>Ação</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Denuncias)
                    {
                        <tr>
                            <td class="text-muted small">@d.DenunciaId</td>
                            <td>
                                <span class="fw-medium">@d.Captura?.Especie?.Nome</span>
                                <small class="d-block text-muted">por @d.Captura?.Utilizador?.NomeCompleto</small>
                            </td>
                            <td class="small text-muted">@d.DenuncianteEmail</td>
                            <td class="small">
                                @(d.Motivo.Length > 50 ? d.Motivo.Substring(0, 50) + "..." : d.Motivo)
                            </td>
                            <td>
                                @switch (d.Estado)
                                {
                                    case EstadoDenuncia.Pendente:
                                        <span class="badge bg-warning text-dark">Pendente</span>
                                        break;
                                    case EstadoDenuncia.Analisada_Valida:
                                        <span class="badge bg-danger">Fraude Confirmada</span>
                                        break;
                                    case EstadoDenuncia.Analisada_Fraude:
                                        <span class="badge bg-secondary">Inválida</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-page="/Denuncia/Detalhes" asp-route-id="@d.DenunciaId" class="btn btn-sm btn-outline-dark">
                                    Analisar
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}