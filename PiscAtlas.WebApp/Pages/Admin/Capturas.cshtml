@page
@model PiscAtlas.WebApp.Pages.Admin.CapturasModel
@{
    ViewData["Title"] = "Admin — Capturas";
    bool pendentes = Model.Pendentes;
}

<div class="mb-4">
    <a asp-page="./Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
    <h2 class="fw-bold mt-2">Gestão de Capturas</h2>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex gap-2 mb-4">
    <a asp-page="./Capturas" asp-route-pendentes="false" class="btn btn-sm @(!pendentes ? "btn-dark" : "btn-outline-dark")">Todas</a>
    <a asp-page="./Capturas" asp-route-pendentes="true" class="btn btn-sm @(pendentes ? "btn-dark" : "btn-outline-dark")">
        Pendentes de aprovação
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Espécie</th>
                    <th>Pesqueiro</th>
                    <th>Utilizador</th>
                    <th>Data</th>
                    <th>Foto</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Capturas)
                {
                    <tr>
                        <td class="fw-medium">@c.Especie?.Nome</td>
                        <td class="small">@c.Pesqueiro?.Nome</td>
                        <td class="small text-muted">@c.Utilizador?.NomeCompleto</td>
                        <td class="small">@c.DataCaptura.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.FotografiaUrl))
                            {
                                <img src="@c.FotografiaUrl" alt="Foto" style="height: 40px; width: 40px; object-fit: cover; border-radius: 4px;" />
                            }
                            else
                            {
                                <span class="badge bg-secondary">Sem foto</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-page="/Captura/Detalhes" asp-route-id="@c.CapturaId" class="btn btn-sm btn-outline-dark py-0" title="Ver Detalhes">
                                    <i class="bi bi-eye"></i>
                                </a>

                                @if (!c.AprovadaPeloAdmin)
                                {
                                    <form asp-page-handler="AprovarCaptura" asp-route-id="@c.CapturaId" asp-route-pendentes="@pendentes" method="post">
                                        <button class="btn btn-sm btn-outline-success py-0" title="Aprovar">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                }

                                <form asp-page-handler="RejeitarCaptura" asp-route-id="@c.CapturaId" asp-route-pendentes="@pendentes" method="post" onsubmit="return confirm('Tem a certeza que deseja rejeitar e apagar esta captura?');">
                                    <button class="btn btn-sm btn-outline-danger py-0" title="Rejeitar/Apagar">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>