@page
@model PiscAtlas.WebApp.Pages.Especie.CriarModel
@{
    ViewData["Title"] = "Adicionar Nova Espécie";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><i class="bi bi-plus-circle"></i> Adicionar Espécie</h2>
            <a asp-page="./Index" class="btn btn-outline-secondary btn-sm">Voltar à Caderneta</a>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="NovaEspecie.Nome" class="form-label fw-bold">Nome Comum *</label>
                        <input asp-for="NovaEspecie.Nome" class="form-control" required placeholder="Ex: Achigã" />
                        <span asp-validation-for="NovaEspecie.Nome" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NovaEspecie.NomeCientifico" class="form-label fw-bold">Nome Científico *</label>
                        <input asp-for="NovaEspecie.NomeCientifico" class="form-control" required placeholder="Ex: Micropterus salmoides" />
                        <span asp-validation-for="NovaEspecie.NomeCientifico" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NovaEspecie.Descricao" class="form-label fw-bold">Descrição</label>
                    <textarea asp-for="NovaEspecie.Descricao" class="form-control" rows="3" placeholder="Breve resumo da espécie..."></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="NovaEspecie.Habitat" class="form-label fw-bold">Habitat *</label>
                    <select asp-for="NovaEspecie.Habitat" asp-items="Html.GetEnumSelectList<PiscAtlas.Models.Models.TipoHabitat>()" class="form-select"></select>
                    <span asp-validation-for="NovaEspecie.Habitat" class="text-danger small"></span>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary fw-bold py-2">
                        <i class="bi bi-save"></i> Guardar Espécie na Base de Dados
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}