@page "{userId?}"
@model PiscAtlas.WebApp.Pages.Especie.IndexModel
@{
    ViewData["Title"] = Model.IsProprio ? "A Minha Caderneta" : $"Caderneta de {Model.CadernetaUser?.NomeCompleto}";
}

<!-- Cabeçalho da Caderneta -->
<div class="mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-book-fill text-dark"></i>
            @(Model.IsProprio ? "A Minha Caderneta de Espécies" : $"Caderneta de {Model.CadernetaUser?.NomeCompleto}")
        </h2>
        <p class="text-muted mb-0">
            @(Model.IsProprio ? "Desbloqueie todas as espécies de peixes de Portugal para subir no ranking!" : "Explore o progresso de capturas e troféus deste pescador.")
        </p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-page="./Criar" class="btn btn-primary fw-bold shadow-sm">
            <i class="bi bi-plus-lg"></i> Adicionar Espécie (Admin)
        </a>
    }
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 mb-4">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
}

<!-- Cartão de Progresso / Estatísticas -->
<div class="card border-0 shadow-sm mb-5 rounded-4 p-4 bg-white">
    <div class="row align-items-center g-3 text-center text-md-start">
        <div class="col-md-5 border-end-md">
            <p class="fw-bold text-muted text-uppercase small mb-1">Progresso Global</p>
            <h3 class="fw-bold mb-1 display-6">@Model.TotalCapturadas <span class="fs-4 text-muted">/ @Model.TotalEspecies</span></h3>
            <small class="text-muted">espécies registadas na caderneta</small>
        </div>

        <div class="col-md-7">
            <div class="row g-2 text-center mb-3">
                <div class="col-4">
                    <h4 class="fw-bold mb-0 text-success">@Model.Percentagem%</h4>
                    <small class="text-muted d-block" style="font-size: 0.75rem;">Concluído</small>
                </div>
                <div class="col-4 border-start border-end">
                    <h4 class="fw-bold mb-0 text-warning">@Model.PorFazer</h4>
                    <small class="text-muted d-block" style="font-size: 0.75rem;">Por Descobrir</small>
                </div>
                <div class="col-4">
                    <h4 class="fw-bold mb-0 text-primary">@Model.Pontos</h4>
                    <small class="text-muted d-block" style="font-size: 0.75rem;">Pontos XP</small>
                </div>
            </div>

            <!-- Barra de Progresso Visual -->
            <div class="progress rounded-pill" style="height: 12px; background-color: #e9ecef;">
                <div class="progress-bar bg-dark rounded-pill transition-all" role="progressbar" style="width: @(Model.Percentagem)%;" aria-valuenow="@Model.Percentagem" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
        </div>
    </div>
</div>

<!-- Grelha de Espécies -->
@if (!Model.TodasEspecies.Any())
{
    <div class="card border-0 shadow-sm text-center py-5 rounded-4">
        <i class="bi bi-fish text-muted" style="font-size: 3.5rem;"></i>
        <h5 class="mt-3 fw-bold">Ainda não existem espécies cadastradas</h5>
        <p class="text-muted small">Os administradores precisam de adicionar peixes ao catálogo.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var peixe in Model.TodasEspecies)
        {
            bool foiCapturado = Model.EspeciesCapturadasIds.Contains(peixe.EspecieId);

            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm rounded-4 overflow-hidden transition @(foiCapturado ? "border-success border-2 bg-white" : "border-0 bg-light opacity-75")">

                    <div class="p-3 pb-0 d-flex justify-content-between align-items-center">
                        <span class="badge @(foiCapturado ? "bg-success" : "bg-secondary") rounded-pill px-3 py-1">
                            @(foiCapturado ? "Desbloqueado" : "Bloqueado")
                        </span>
                        @if (foiCapturado)
                        {
                            <i class="bi bi-check-circle-fill text-success fs-4" title="Já capturou esta espécie!"></i>
                        }
                        else
                        {
                            <i class="bi bi-lock-fill text-muted fs-5" title="Ainda não capturado"></i>
                        }
                    </div>

                    <div class="card-body text-center p-3 d-flex flex-column justify-content-between">
                        <div class="my-3">
                            <div class="rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center @(foiCapturado ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")" style="width: 70px; height: 70px;">
                                <i class="bi bi-droplet-fill fs-2"></i>
                            </div>

                            <h5 class="fw-bold mb-0 text-dark">@peixe.Nome</h5>
                            <small class="text-muted fst-italic d-block mb-2">@peixe.NomeCientifico</small>

                            <!-- CORREÇÃO DO ERRO CS1503 AQUI: Formatação direta do Enum -->
                            <span class="badge bg-light text-dark border small fw-normal">@peixe.Habitat.ToString().Replace("_", " ")</span>
                        </div>

                        <p class="text-muted small mb-3" style="font-size: 0.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @(string.IsNullOrEmpty(peixe.Descricao) ? "Sem informações adicionais." : peixe.Descricao)
                        </p>

                        <div class="border-top pt-2 mt-auto d-flex justify-content-between align-items-center small text-muted">
                            <span><i class="bi bi-trophy me-1 text-warning"></i> @(peixe.PesoRecordPt.HasValue ? $"{peixe.PesoRecordPt} kg" : "---")</span>
                            <span class="fw-bold text-dark">+100 XP</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}