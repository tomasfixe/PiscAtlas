@model PiscAtlas.Models.Models.Pesqueiro

@{
    ViewData["Title"] = "Eliminar Pesqueiro";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Confirmar Eliminação</h4>
            </div>
            <div class="card-body text-center">
                <h5 class="card-title mt-3">Tem a certeza que deseja eliminar este pesqueiro?</h5>
                <p class="text-muted"><strong>@Model.Nome</strong></p>

                @if (Model.Capturas != null && Model.Capturas.Any())
                {
                    <div class="alert alert-warning">
                        <strong>Aviso:</strong> Este pesqueiro tem @Model.Capturas.Count capturas associadas. Se o eliminar, pode afetar os registos dos utilizadores!
                    </div>
                }

                <form asp-action="Eliminar" method="post" class="mt-4">
                    <input type="hidden" asp-for="PesqueiroId" />
                    <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                    <button type="submit" class="btn btn-danger">Sim, Eliminar Definitivamente</button>
                </form>
            </div>
        </div>
    </div>
</div>