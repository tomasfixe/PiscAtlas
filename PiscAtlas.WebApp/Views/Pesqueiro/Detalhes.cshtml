@model PiscAtlas.Models.Models.Pesqueiro
@{
    ViewData["Title"] = Model.Nome;
    var topCapturas = ViewBag.TopCapturas as List<PiscAtlas.Models.Models.Captura>;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Voltar aos Pesqueiros
    </a>
</div>

<div class="row g-4 mb-5">
    <div class="col-lg-5">
        <div class="rounded-3 overflow-hidden shadow-sm" style="height: 300px; background: #f8f9fa;">
            @if (!string.IsNullOrEmpty(Model.FotografiaUrl))
            {
                <img src="@Model.FotografiaUrl" alt="@Model.Nome"
                     class="w-100 h-100" style="object-fit: cover;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center h-100">
                    <i class="bi bi-water text-secondary" style="font-size: 3rem;"></i>
                </div>
            }
        </div>
    </div>
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h2 class="fw-bold mb-0">@Model.Nome</h2>
            <span class="badge bg-light text-dark border fs-6">
                @Model.Tipo.ToString().Replace("_", " ")
            </span>
        </div>
        <p class="text-muted mb-4">@(Model.Descricao ?? "Sem descrição disponível.")</p>

        <div class="card border-0 bg-light p-3 mb-4">
            <div class="row text-center">
                <div class="col-6 border-end">
                    <h4 class="fw-bold mb-0">@(Model.Capturas?.Count ?? 0)</h4>
                    <small class="text-muted">Capturas registadas</small>
                </div>
                <div class="col-6">
                    <h4 class="fw-bold mb-0">
                        @(Model.Capturas?.Where(c => c.Peso.HasValue).OrderByDescending(c => c.Peso).FirstOrDefault()?.Peso?.ToString("0.##") ?? "—")
                    </h4>
                    <small class="text-muted">Maior captura (kg)</small>
                </div>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a asp-controller="Captura" asp-action="Criar" class="btn btn-dark fw-medium">
                <i class="bi bi-camera"></i> Registar Captura aqui
            </a>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="d-flex gap-2 mt-2">
                <a asp-action="Editar" asp-route-id="@Model.PesqueiroId"
                   class="btn btn-sm btn-outline-dark">
                    <i class="bi bi-pencil"></i> Editar
                </a>
                <a asp-action="Eliminar" asp-route-id="@Model.PesqueiroId"
                   class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i> Eliminar
                </a>
            </div>
        }
    </div>
</div>

@* Mini mapa *@
@if (Model.Latitude != 0 && Model.Longitude != 0)
{
    <div class="mb-5">
        <h5 class="fw-bold mb-3">Localização</h5>
        <div class="rounded-3 overflow-hidden shadow-sm">
            <div id="miniMapa" style="height: 300px;"></div>
        </div>
    </div>
}

@* Top capturas *@
@if (topCapturas != null && topCapturas.Any())
{
    <div class="mb-5">
        <h5 class="fw-bold mb-3"><i class="bi bi-trophy"></i> Top Capturas neste Pesqueiro</h5>
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Pescador</th>
                            <th>Espécie</th>
                            <th>Peso</th>
                            <th>Data</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int rank = 1; }
                        @foreach (var c in topCapturas)
                        {
                            <tr>
                                <td>
                                    @if (rank == 1) { <i class="bi bi-trophy-fill text-warning"></i> }
                                    else if (rank == 2) { <i class="bi bi-trophy-fill text-secondary"></i> }
                                    else if (rank == 3) { <i class="bi bi-trophy-fill" style="color: #cd7f32;"></i> }
                                    else { <span class="text-muted">@rank</span> }
                                </td>
                                <td>@c.Utilizador?.NomeCompleto</td>
                                <td>@c.Especie?.Nome</td>
                                <td><strong>@c.Peso kg</strong></td>
                                <td class="text-muted small">@c.DataCaptura.ToString("dd/MM/yyyy")</td>
                            </tr>
                            rank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* Capturas recentes *@
<div class="mb-5">
    <h5 class="fw-bold mb-3">Capturas Recentes</h5>
    @{
        var capturas = Model.Capturas?.OrderByDescending(c => c.DataCaptura).Take(6).ToList();
    }
    @if (capturas == null || !capturas.Any())
    {
        <p class="text-muted">Ainda sem capturas neste pesqueiro.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var c in capturas)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Captura" asp-action="Detalhes" asp-route-id="@c.CapturaId"
                       class="text-decoration-none">
                        <div class="rounded-3 overflow-hidden shadow-sm" style="height: 130px; background: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(c.FotografiaUrl))
                            {
                                <img src="@c.FotografiaUrl" alt="@c.Especie?.Nome"
                                     class="w-100 h-100" style="object-fit: cover;" />
                            }
                        </div>
                        <p class="small fw-medium mt-1 mb-0 text-dark">@c.Especie?.Nome</p>
                        <p class="small text-muted">@c.DataCaptura.ToString("dd/MM/yy")</p>
                    </a>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    @if (Model.Latitude != 0 && Model.Longitude != 0)
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            var map = L.map('miniMapa').setView([@Model.Latitude, @Model.Longitude], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 18,
                attribution: '© OpenStreetMap contributors'
            }).addTo(map);
            L.marker([@Model.Latitude, @Model.Longitude])
                .addTo(map)
                .bindPopup("<b>@Model.Nome</b>")
                .openPopup();
        </script>
    }
}
