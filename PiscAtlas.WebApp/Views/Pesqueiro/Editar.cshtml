@model PiscAtlas.WebApp.Controllers.PesqueiroViewModel

@{
    ViewData["Title"] = "Editar Pesqueiro";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">Editar Pesqueiro</h2>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Voltar à Lista</a>
        </div>

        <div class="card shadow-sm p-4">
            <form asp-action="Editar" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" name="id" value="@ViewBag.PesqueiroId" />

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Nome" class="form-label fw-bold">Nome *</label>
                        <input asp-for="Nome" class="form-control" required />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Tipo" class="form-label fw-bold">Tipo de Pesqueiro *</label>
                        <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<PiscAtlas.Models.Models.TipoPesqueiro>()" class="form-select"></select>
                        <span asp-validation-for="Tipo" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Descricao" class="form-label fw-bold">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control" rows="3"></textarea>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Latitude" class="form-label fw-bold">Latitude</label>
                        <input asp-for="Latitude" type="number" step="0.000001" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Longitude" class="form-label fw-bold">Longitude</label>
                        <input asp-for="Longitude" type="number" step="0.000001" class="form-control" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="FotoFile" class="form-label fw-bold">Nova Fotografia (Opcional)</label>
                    <input asp-for="FotoFile" type="file" class="form-control" accept="image/*" />
                    <small class="text-muted">Deixe em branco para manter a fotografia atual.</small>

                    @if (!string.IsNullOrEmpty(ViewBag.FotoAtual))
                    {
                        <div class="mt-2">
                            <p class="mb-1 small fw-bold">Foto Atual:</p>
                            <img src="@ViewBag.FotoAtual" alt="Foto atual do pesqueiro" class="img-thumbnail" style="max-height: 100px;" />
                        </div>
                    }
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary fw-bold">Guardar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}