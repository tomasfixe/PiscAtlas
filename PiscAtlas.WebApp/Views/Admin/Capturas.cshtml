@model IEnumerable<PiscAtlas.Models.Models.Captura>
@{
    ViewData["Title"] = "Admin — Capturas";
    bool pendentes = ViewBag.Pendentes;
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Dashboard
    </a>
    <h2 class="fw-bold mt-2">Gestão de Capturas</h2>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex gap-2 mb-4">
    <a asp-action="Capturas" class="btn btn-sm @(!pendentes ? "btn-dark" : "btn-outline-dark")">Todas</a>
    <a asp-action="Capturas" asp-route-pendentes="true"
       class="btn btn-sm @(pendentes ? "btn-dark" : "btn-outline-dark")">
        Pendentes de aprovação
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Foto</th>
                    <th>Espécie</th>
                    <th>Pescador</th>
                    <th>Pesqueiro</th>
                    <th>Peso</th>
                    <th>Data</th>
                    <th>Estado</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(c.FotografiaUrl))
                            {
                                <img src="@c.FotografiaUrl" alt="Captura"
                                     class="rounded" style="width: 50px; height: 40px; object-fit: cover;" />
                            }
                        </td>
                        <td class="fw-medium">@c.Especie?.Nome</td>
                        <td class="text-muted small">@c.Utilizador?.NomeCompleto</td>
                        <td class="text-muted small">@c.Pesqueiro?.Nome</td>
                        <td>@(c.Peso.HasValue ? $"{c.Peso} kg" : "—")</td>
                        <td class="small text-muted">@c.DataCaptura.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (c.AprovadaPeloAdmin)
                            {
                                <span class="badge bg-success">Aprovada</span>
                            }
                            else if (c.PossuiProvasVisuais)
                            {
                                <span class="badge bg-warning text-dark">Pendente</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Sem foto</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                @if (!c.AprovadaPeloAdmin && c.PossuiProvasVisuais)
                                {
                                    <form asp-action="AprovarCaptura" asp-route-id="@c.CapturaId" method="post">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-success py-0">
                                            <i class="bi bi-check"></i>
                                        </button>
                                    </form>
                                }
                                @if (c.AprovadaPeloAdmin)
                                {
                                    <form asp-action="RejeitarCaptura" asp-route-id="@c.CapturaId" method="post">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger py-0">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
