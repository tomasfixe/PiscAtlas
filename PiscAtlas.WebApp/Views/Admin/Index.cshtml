@model PiscAtlas.WebApp.Controllers.AdminDashboardViewModel
@{
    ViewData["Title"] = "Painel de Administração";
}

<div class="mb-5">
    <h2 class="fw-bold mb-0"><i class="bi bi-shield-lock"></i> Painel de Administração</h2>
    <p class="text-muted">Gestão da plataforma PiscAtlas</p>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Estatísticas *@
<div class="row g-4 mb-5">
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm p-4 text-center">
            <i class="bi bi-people fs-1 text-dark mb-2"></i>
            <h2 class="fw-bold mb-0">@Model.TotalUtilizadores</h2>
            <small class="text-muted">Utilizadores</small>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm p-4 text-center">
            <i class="bi bi-camera fs-1 text-dark mb-2"></i>
            <h2 class="fw-bold mb-0">@Model.TotalCapturas</h2>
            <small class="text-muted">Capturas</small>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm p-4 text-center">
            <i class="bi bi-geo-alt fs-1 text-dark mb-2"></i>
            <h2 class="fw-bold mb-0">@Model.TotalPesqueiros</h2>
            <small class="text-muted">Pesqueiros</small>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card border-0 shadow-sm p-4 text-center @(Model.TotalDenunciasPendentes > 0 ? "border-danger border" : "")">
            <i class="bi bi-flag fs-1 @(Model.TotalDenunciasPendentes > 0 ? "text-danger" : "text-dark") mb-2"></i>
            <h2 class="fw-bold mb-0 @(Model.TotalDenunciasPendentes > 0 ? "text-danger" : "")">
                @Model.TotalDenunciasPendentes
            </h2>
            <small class="text-muted">Denúncias pendentes</small>
        </div>
    </div>
</div>

@* Acesso rápido *@
<div class="row g-3 mb-5">
    <div class="col-12">
        <h5 class="fw-bold mb-3">Acesso Rápido</h5>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Capturas" asp-route-pendentes="true"
           class="btn btn-outline-dark w-100 py-3 d-flex flex-column align-items-center">
            <i class="bi bi-clock fs-4 mb-1"></i>
            <small>Capturas a Aprovar</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Denuncias" class="btn btn-outline-danger w-100 py-3 d-flex flex-column align-items-center">
            <i class="bi bi-flag fs-4 mb-1"></i>
            <small>Gerir Denúncias</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-action="Utilizadores" class="btn btn-outline-dark w-100 py-3 d-flex flex-column align-items-center">
            <i class="bi bi-people fs-4 mb-1"></i>
            <small>Utilizadores</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Pesqueiro" asp-action="Criar"
           class="btn btn-outline-dark w-100 py-3 d-flex flex-column align-items-center">
            <i class="bi bi-geo-alt-fill fs-4 mb-1"></i>
            <small>Adicionar Pesqueiro</small>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Evento" asp-action="Criar"
           class="btn btn-outline-dark w-100 py-3 d-flex flex-column align-items-center">
            <i class="bi bi-calendar-plus fs-4 mb-1"></i>
            <small>Criar Evento / Torneio</small>
        </a>
    </div>
</div>

@* Capturas recentes *@
<div class="row g-4">
    <div class="col-lg-6">
        <h5 class="fw-bold mb-3">Últimas Capturas</h5>
        <div class="card border-0 shadow-sm">
            @if (!Model.CapturasRecentes.Any())
            {
                <div class="card-body text-center text-muted py-4">Sem capturas</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var c in Model.CapturasRecentes)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div>
                                <span class="fw-medium">@c.Especie?.Nome</span>
                                <small class="d-block text-muted">por @c.Utilizador?.NomeCompleto</small>
                            </div>
                            <div class="text-end">
                                @if (c.AprovadaPeloAdmin)
                                {
                                    <span class="badge bg-success">Aprovada</span>
                                }
                                else if (c.PossuiProvasVisuais)
                                {
                                    <form asp-action="AprovarCaptura" asp-route-id="@c.CapturaId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-xs btn-outline-success btn-sm py-0">
                                            <i class="bi bi-check"></i> Aprovar
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Sem foto</span>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="text-end mt-2">
            <a asp-action="Capturas" class="small text-muted text-decoration-none">
                Ver todas <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>

    <div class="col-lg-6">
        <h5 class="fw-bold mb-3">Denúncias Pendentes</h5>
        <div class="card border-0 shadow-sm">
            @if (!Model.DenunciasPendentes.Any())
            {
                <div class="card-body text-center text-muted py-4">
                    <i class="bi bi-check-circle text-success fs-4 d-block mb-2"></i>
                    Sem denúncias pendentes
                </div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var d in Model.DenunciasPendentes)
                    {
                        <li class="list-group-item py-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="fw-medium">@d.Captura?.Especie?.Nome</span>
                                <small class="text-muted">por @d.Captura?.Utilizador?.NomeCompleto</small>
                            </div>
                            <p class="small text-muted mb-2">
                                "@(d.Motivo.Length > 60 ? d.Motivo.Substring(0, 60) + "..." : d.Motivo)"
                            </p>
                            <a asp-action="Detalhes" asp-controller="Denuncia"
                               asp-route-id="@d.DenunciaId"
                               class="btn btn-sm btn-outline-danger">
                                Analisar <i class="bi bi-arrow-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="text-end mt-2">
            <a asp-action="Denuncias" class="small text-muted text-decoration-none">
                Ver todas <i class="bi bi-arrow-right"></i>
            </a>
        </div>
    </div>
</div>
