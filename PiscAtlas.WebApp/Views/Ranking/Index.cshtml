@model IEnumerable<PiscAtlas.Models.Models.Captura>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Rankings";
}

<div class="mb-5">
    <h2 class="fw-bold mb-0"><i class="bi bi-trophy"></i> Rankings</h2>
    <p class="text-muted">As maiores capturas aprovadas registadas na plataforma</p>
</div>

<form method="get" asp-action="Index" class="mb-4 d-flex gap-2 align-items-center">
    <label class="fw-medium small text-muted">Filtrar por espécie:</label>
    <select name="especieId" class="form-select w-auto" onchange="this.form.submit()">
        <option value="">Todas as espécies</option>
        @foreach (var item in (SelectList)ViewBag.Especies)
        {
            if (item.Selected)
            {
                <option value="@item.Value" selected>@item.Text</option>
            }
            else
            {
                <option value="@item.Value">@item.Text</option>
            }
        }
    </select>
</form>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-trophy text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 fw-bold">Ainda sem capturas aprovadas</h4>
            <p class="text-muted">Quando o admin aprovar capturas com peso registado, elas aparecem aqui.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Espécie</th>
                        <th>Pescador</th>
                        <th>Pesqueiro</th>
                        <th>Peso</th>
                        <th>Tamanho</th>
                        <th>Data</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int posicao = 1; }
                    @foreach (var captura in Model)
                    {
                        <tr>
                            <td>
                                @if (posicao == 1)
                                {
                                    <span class="badge bg-warning text-dark">🥇 @posicao</span>
                                }
                                else if (posicao == 2)
                                {
                                    <span class="badge bg-secondary">🥈 @posicao</span>
                                }
                                else if (posicao == 3)
                                {
                                    <span class="badge bg-dark">🥉 @posicao</span>
                                }
                                else
                                {
                                    <span class="text-muted">@posicao</span>
                                }
                            </td>
                            <td class="fw-medium">@captura.Especie?.Nome</td>
                            <td>@captura.Utilizador?.NomeCompleto</td>
                            <td class="text-muted small">@captura.Pesqueiro?.Nome</td>
                            <td><span class="badge bg-light text-dark border">@captura.Peso kg</span></td>
                            <td>@(captura.Tamanho.HasValue ? captura.Tamanho + " cm" : "—")</td>
                            <td class="text-muted small">@captura.DataCaptura.ToString("dd/MM/yyyy")</td>
                        </tr>
                        posicao++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}
