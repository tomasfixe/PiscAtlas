@model PiscAtlas.Models.Models.Evento
@{
    ViewData["Title"] = Model.Nome;
    bool jaInscrito = ViewBag.JaInscrito == true;
    bool aberto     = Model.DataFim >= DateTime.Now;
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Voltar aos Eventos
    </a>
    @if (User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2">
            <a asp-action="Editar" asp-route-id="@Model.EventoId" class="btn btn-sm btn-outline-dark">
                <i class="bi bi-pencil"></i> Editar
            </a>
            <a asp-action="Eliminar" asp-route-id="@Model.EventoId" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i> Eliminar
            </a>
        </div>
    }
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-x-circle"></i> @TempData["Erro"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <h2 class="fw-bold mb-1">@Model.Nome</h2>
        <div class="d-flex gap-2 mb-3">
            @if (aberto)
            {
                <span class="badge bg-success">Inscrições abertas</span>
            }
            else
            {
                <span class="badge bg-secondary">Encerrado</span>
            }
        </div>

        <p class="text-muted mb-4">@Model.Descricao</p>

        <div class="card border-0 bg-light p-4 mb-4">
            <h6 class="fw-bold mb-3">Detalhes do Evento</h6>
            <ul class="list-unstyled mb-0">
                <li class="mb-2">
                    <i class="bi bi-calendar3 me-2 text-muted"></i>
                    <strong>Início:</strong> @Model.DataInicio.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-PT"))
                </li>
                <li class="mb-2">
                    <i class="bi bi-calendar-x me-2 text-muted"></i>
                    <strong>Fim:</strong> @Model.DataFim.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-PT"))
                </li>
                <li class="mb-2">
                    <i class="bi bi-fish me-2 text-muted"></i>
                    <strong>Espécie alvo:</strong> @Model.EspecieAlvo?.Nome
                </li>
                @if (Model.PesoMinimo.HasValue)
                {
                    <li class="mb-2">
                        <i class="bi bi-arrow-up-circle me-2 text-muted"></i>
                        <strong>Peso mínimo:</strong> @Model.PesoMinimo kg
                    </li>
                }
                @if (Model.TamanhoMinimo.HasValue)
                {
                    <li class="mb-2">
                        <i class="bi bi-rulers me-2 text-muted"></i>
                        <strong>Comprimento mínimo:</strong> @Model.TamanhoMinimo cm
                    </li>
                }
                <li>
                    <i class="bi bi-people me-2 text-muted"></i>
                    <strong>Inscrições:</strong> @(Model.Inscricoes?.Count ?? 0) participantes
                </li>
            </ul>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm p-4 text-center sticky-top" style="top: 80px;">
            <h3 class="fw-bold mb-1">@Model.PrecoInscricao €</h3>
            <p class="text-muted small mb-4">Taxa de inscrição</p>

            @if (!User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-controller="Conta" asp-action="Login"
                   class="btn btn-dark w-100 fw-bold mb-2">
                    <i class="bi bi-person"></i> Iniciar sessão para se inscrever
                </a>
            }
            else if (jaInscrito)
            {
                <div class="alert alert-success mb-0">
                    <i class="bi bi-check-circle-fill"></i> Já está inscrito neste evento!
                </div>
            }
            else if (!aberto)
            {
                <div class="alert alert-secondary mb-0">
                    Inscrições encerradas
                </div>
            }
            else
            {
                <form asp-action="Inscrever" asp-route-id="@Model.EventoId" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-dark w-100 fw-bold py-2">
                        <i class="bi bi-trophy"></i> Inscrever-me neste Evento
                    </button>
                </form>
                <p class="text-muted small mt-2">
                    <i class="bi bi-info-circle"></i> O pagamento é confirmado após inscrição.
                </p>
            }
        </div>
    </div>
</div>

@if (Model.Inscricoes != null && Model.Inscricoes.Any())
{
    <div class="mt-5">
        <h5 class="fw-bold mb-3">Participantes (@Model.Inscricoes.Count)</h5>
        <div class="card border-0 shadow-sm">
            <ul class="list-group list-group-flush">
                @foreach (var i in Model.Inscricoes.Take(20))
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-person-circle me-2 text-muted"></i>@i.PescadorNome</span>
                        <span class="badge @(i.EstadoPagamento == PiscAtlas.Models.Models.EstadoPagamento.Pago ? "bg-success" : "bg-warning text-dark")">
                            @i.EstadoPagamento
                        </span>
                    </li>
                }
            </ul>
        </div>
    </div>
}
