@model PiscAtlas.WebApp.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
            <h2 class="fw-bold"><i class="bi bi-tsunami"></i> PiscAtlas</h2>
            <p class="text-muted">Bem-vindo de volta! Inicie sessão na sua conta.</p>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <form asp-controller="Conta" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-medium">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="nome@exemplo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-medium">Palavra-passe</label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="LembrarMe" class="form-check-input" />
                    <label asp-for="LembrarMe" class="form-check-label text-muted">Mantenha-me com sessão iniciada</label>
                </div>

                <button type="submit" class="btn btn-dark w-100 fw-bold py-2">Entrar</button>
            </form>
        </div>

        <div class="text-center mt-4">
            <p class="text-muted">Ainda não tem conta? <a asp-action="Registar" class="text-dark fw-bold text-decoration-none">Criar Conta</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}