@model PiscAtlas.WebApp.ViewModels.RegistarViewModel
@{
    ViewData["Title"] = "Criar Conta";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7 col-lg-6">
        <div class="text-center mb-4">
            <h2 class="fw-bold"><i class="bi bi-tsunami"></i> PiscAtlas</h2>
            <p class="text-muted">Junte-se à maior comunidade de pescadores em Portugal.</p>
        </div>

        <div class="card border-0 shadow-sm p-4">
            <form asp-controller="Conta" asp-action="Registar" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PrimeiroNome" class="form-label fw-medium"></label>
                        <input asp-for="PrimeiroNome" class="form-control" placeholder="João" />
                        <span asp-validation-for="PrimeiroNome" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="UltimoNome" class="form-label fw-medium"></label>
                        <input asp-for="UltimoNome" class="form-control" placeholder="Silva" />
                        <span asp-validation-for="UltimoNome" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="NomeUtilizador" class="form-label fw-medium"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">@@</span>
                        <input asp-for="NomeUtilizador" class="form-control border-start-0 ps-0" placeholder="joaosilva_pesca" />
                    </div>
                    <span asp-validation-for="NomeUtilizador" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-medium"></label>
                    <input asp-for="Email" class="form-control" placeholder="joao@exemplo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Password" class="form-label fw-medium">Palavra-passe</label>
                        <input asp-for="Password" class="form-control" placeholder="Mínimo 6 caracteres" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-medium">Confirmar</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repita a palavra-passe" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100 fw-bold py-2">Criar Conta</button>
            </form>
        </div>

        <div class="text-center mt-4">
            <p class="text-muted">Já tem uma conta? <a asp-action="Login" class="text-dark fw-bold text-decoration-none">Entrar</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}