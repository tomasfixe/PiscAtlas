@{
    ViewData["Title"] = "Oops! Algo correu mal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container text-center py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <i class="bi bi-droplet-half text-danger mb-3" style="font-size: 5rem;"></i>

            <h1 class="display-1 fw-bold text-secondary">@ViewData["CodigoErro"]</h1>
            <h3 class="mb-4 text-dark">Águas Turvas Pela Frente</h3>

            <p class="lead text-muted mb-5">
                @ViewData["MensagemErro"]
            </p>

            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">
                <i class="bi bi-house-door"></i> Voltar ao Porto Seguro (Início)
            </a>
        </div>
    </div>
</div>