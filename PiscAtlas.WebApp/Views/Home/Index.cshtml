@model PiscAtlas.WebApp.Controllers.HomeViewModel
@{
    ViewData["Title"] = "PiscAtlas - Início";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<div class="mb-5">
    <h1 class="display-5 fw-bold text-dark"><i class="bi bi-tsunami"></i> PiscAtlas</h1>
    <p class="text-muted fs-5">Explore pesqueiros e capturas em Portugal</p>
</div>

<ul class="nav nav-tabs mb-4" id="piscAtlasTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold text-dark d-flex align-items-center gap-2" id="mapa-tab" data-bs-toggle="tab" data-bs-target="#mapa" type="button" role="tab" aria-selected="true">
            <i class="bi bi-geo-alt-fill"></i> Mapa Interativo
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-dark d-flex align-items-center gap-2" id="capturas-tab" data-bs-toggle="tab" data-bs-target="#capturas" type="button" role="tab" aria-selected="false">
            <i class="bi bi-camera"></i> Capturas Recentes
        </button>
    </li>
</ul>

<div class="tab-content" id="piscAtlasTabsContent">

    <div class="tab-pane fade show active" id="mapa" role="tabpanel" aria-labelledby="mapa-tab">
        <div class="card border-0 shadow-sm overflow-hidden">
            <div id="mapaInterativo" style="height: 650px; width: 100%; z-index: 1;"></div>
        </div>
    </div>

    <div class="tab-pane fade" id="capturas" role="tabpanel" aria-labelledby="capturas-tab">
        <div class="row g-4">
            @if (!Model.Capturas.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-camera text-muted" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-muted">Ainda não existem capturas registadas.</h5>
                </div>
            }

            @foreach (var captura in Model.Capturas)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px; overflow: hidden;">
                            @if (!string.IsNullOrEmpty(captura.FotografiaUrl))
                            {
                                <img src="@captura.FotografiaUrl" alt="Captura de @captura.Especie?.Nome" class="w-100 h-100" style="object-fit: cover;" />
                            }
                            else
                            {
                                <i class="bi bi-image text-secondary" style="font-size: 2rem;"></i>
                            }
                        </div>
                        <div class="card-body">
                            <h5 class="fw-bold mb-1">@captura.Especie?.Nome</h5>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-geo-alt"></i> @captura.Pesqueiro?.Nome <br />
                                <i class="bi bi-person"></i> @captura.Utilizador?.NomeCompleto
                            </p>
                            <div class="d-flex justify-content-between mb-0">
                                <span class="badge bg-light text-dark border">@captura.Peso kg</span>
                                <span class="badge bg-light text-dark border">@captura.Tamanho cm</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pt-0">
                            <button class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-flag"></i> Denunciar
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // 1. Inicializar o Mapa centrado em Portugal
            var map = L.map('mapaInterativo').setView([39.3999, -8.2245], 6);

            // 2. Adicionar os "Azulejos" (Tiles) do OpenStreetMap
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 18,
                attribution: '© OpenStreetMap contributors - PiscAtlas'
            }).addTo(map);

            // 3. Converter os Pesqueiros em C# para um Array JavaScript
            // Nota: Garanta que o modelo 'Pesqueiro' tem 'Latitude' e 'Longitude'
            var pesqueiros = @Html.Raw(Json.Serialize(Model.Pesqueiros.Select(p => new
            {
                id = p.PesqueiroId,
                nome = p.Nome,
                lat = p.Latitude,
                lng = p.Longitude
            })));

            // 4. Desenhar os Pins no mapa
            pesqueiros.forEach(function(p) {
                if(p.lat && p.lng) {
                    var marker = L.marker([p.lat, p.lng]).addTo(map);
                    marker.bindPopup("<b>" + p.nome + "</b><br>Clique para ver detalhes.");
                }
            });

            // 5. Truque para o mapa não ficar cortado ao mudar de separador
            var mapaTabButton = document.getElementById('mapa-tab');
            mapaTabButton.addEventListener('shown.bs.tab', function () {
                map.invalidateSize();
            });
        });
    </script>
}