@model PiscAtlas.Models.Models.Captura
@{
    ViewData["Title"] = "Detalhes da Captura";
}

<div class="mb-4">
    <a asp-action="Index" class="text-muted text-decoration-none small">
        <i class="bi bi-arrow-left"></i> Voltar às Capturas
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="rounded-3 overflow-hidden shadow-sm bg-light" style="height: 380px;">
            @if (!string.IsNullOrEmpty(Model.FotografiaUrl))
            {
                <img src="@Model.FotografiaUrl" alt="Captura"
                     class="w-100 h-100" style="object-fit: cover;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center h-100">
                    <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-7">
        <div class="d-flex align-items-start justify-content-between mb-2">
            <h2 class="fw-bold mb-0">@Model.Especie?.Nome</h2>
            @if (Model.AprovadaPeloAdmin)
            {
                <span class="badge bg-success fs-6">
                    <i class="bi bi-patch-check"></i> Aprovada
                </span>
            }
            else if (Model.PossuiProvasVisuais)
            {
                <span class="badge bg-warning text-dark fs-6">
                    <i class="bi bi-clock"></i> Aguarda Aprovação
                </span>
            }
        </div>
        <p class="text-muted fst-italic mb-4">@Model.Especie?.NomeCientifico</p>

        <div class="row g-3 mb-4">
            <div class="col-6">
                <div class="card border-0 bg-light p-3 text-center">
                    <p class="text-muted small mb-1">Peso</p>
                    <h4 class="fw-bold mb-0">@(Model.Peso.HasValue ? $"{Model.Peso} kg" : "—")</h4>
                </div>
            </div>
            <div class="col-6">
                <div class="card border-0 bg-light p-3 text-center">
                    <p class="text-muted small mb-1">Comprimento</p>
                    <h4 class="fw-bold mb-0">@(Model.Tamanho.HasValue ? $"{Model.Tamanho} cm" : "—")</h4>
                </div>
            </div>
        </div>

        <ul class="list-unstyled">
            <li class="mb-2">
                <i class="bi bi-geo-alt text-muted me-2"></i>
                <strong>Pesqueiro:</strong>
                <a asp-controller="Pesqueiro" asp-action="Detalhes"
                   asp-route-id="@Model.PesqueiroId" class="text-dark">
                    @Model.Pesqueiro?.Nome
                </a>
            </li>
            <li class="mb-2">
                <i class="bi bi-person text-muted me-2"></i>
                <strong>Pescador:</strong> @Model.Utilizador?.NomeCompleto
            </li>
            <li class="mb-2">
                <i class="bi bi-calendar3 text-muted me-2"></i>
                <strong>Data:</strong> @Model.DataCaptura.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("pt-PT"))
            </li>
        </ul>

        @if (!string.IsNullOrEmpty(Model.Notas))
        {
            <div class="mt-3 p-3 bg-light rounded-3">
                <p class="mb-1 fw-medium small text-muted">Notas do pescador</p>
                <p class="mb-0">@Model.Notas</p>
            </div>
        }

        @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
        {
            <div class="mt-4">
                <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
                        data-bs-target="#modalDenuncia">
                    <i class="bi bi-flag"></i> Denunciar captura
                </button>
            </div>
        }
    </div>
</div>

@* Modal de denúncia *@
<div class="modal fade" id="modalDenuncia" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Denunciar Captura</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Denuncia" asp-action="Criar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="CapturaId" value="@Model.CapturaId" />
                <div class="modal-body">
                    <p class="text-muted small">Descreva o motivo pelo qual considera esta captura fraudulenta ou inapropriada.</p>
                    <textarea name="Motivo" class="form-control" rows="4"
                              placeholder="Ex: O peso indicado não parece credível, imagem parece editada..."
                              required maxlength="500"></textarea>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger fw-medium">
                        <i class="bi bi-flag"></i> Submeter Denúncia
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
