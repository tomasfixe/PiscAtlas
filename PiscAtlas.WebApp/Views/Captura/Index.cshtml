@model IEnumerable<PiscAtlas.Models.Models.Captura>
@{
    ViewData["Title"] = "As Minhas Capturas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-camera"></i> As Minhas Capturas</h2>
        <p class="text-muted mb-0">O seu registo pessoal de pescas</p>
    </div>
    <a asp-action="Criar" class="btn btn-dark fw-medium">
        <i class="bi bi-plus-lg"></i> Registar Captura
    </a>
</div>

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["Sucesso"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-camera text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 fw-bold">Ainda não registou capturas</h4>
            <p class="text-muted">Comece já a registar as suas pescas!</p>
            <a asp-action="Criar" class="btn btn-dark mt-2">
                <i class="bi bi-plus-lg"></i> Registar Primeira Captura
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var captura in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="position-relative" style="height: 200px; overflow: hidden; background: #f8f9fa;">
                        @if (!string.IsNullOrEmpty(captura.FotografiaUrl))
                        {
                            <img src="@captura.FotografiaUrl"
                                 alt="@captura.Especie?.Nome"
                                 class="w-100 h-100"
                                 style="object-fit: cover;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-image text-secondary" style="font-size: 2.5rem;"></i>
                            </div>
                        }
                        @if (captura.AprovadaPeloAdmin)
                        {
                            <span class="position-absolute top-0 end-0 m-2 badge bg-success">
                                <i class="bi bi-patch-check"></i> Aprovada
                            </span>
                        }
                        else if (captura.PossuiProvasVisuais)
                        {
                            <span class="position-absolute top-0 end-0 m-2 badge bg-warning text-dark">
                                <i class="bi bi-clock"></i> Pendente
                            </span>
                        }
                    </div>
                    <div class="card-body">
                        <h5 class="fw-bold mb-1">@captura.Especie?.Nome</h5>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-geo-alt"></i> @captura.Pesqueiro?.Nome
                        </p>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-calendar3"></i> @captura.DataCaptura.ToString("dd/MM/yyyy")
                        </p>
                        <div class="d-flex gap-2 mb-2">
                            @if (captura.Peso.HasValue)
                            {
                                <span class="badge bg-light text-dark border">@captura.Peso kg</span>
                            }
                            @if (captura.Tamanho.HasValue)
                            {
                                <span class="badge bg-light text-dark border">@captura.Tamanho cm</span>
                            }
                        </div>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2 pt-0 pb-3 px-3">
                        <a asp-action="Detalhes" asp-route-id="@captura.CapturaId"
                           class="btn btn-sm btn-outline-secondary flex-fill">
                            <i class="bi bi-eye"></i> Ver
                        </a>
                        <a asp-action="Editar" asp-route-id="@captura.CapturaId"
                           class="btn btn-sm btn-outline-dark flex-fill">
                            <i class="bi bi-pencil"></i> Editar
                        </a>
                        <a asp-action="Eliminar" asp-route-id="@captura.CapturaId"
                           class="btn btn-sm btn-outline-danger flex-fill">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
